:{$PORT:8080} {
    encode gzip

    # 1. API Proxy: Handle all requests starting with /api
    handle /api* {
        reverse_proxy https://ecosystem-back-production.up.railway.app {
            header_up Host ecosystem-back-production.up.railway.app
        }
    }

    # 2. Static Files & SPA Routing: Catch-all fallback for Angular frontend
    handle {
        root * dist/control-ecosystem/browser
        try_files {path} /index.html
        file_server
    }
}
